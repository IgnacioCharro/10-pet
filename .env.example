# ============================================================
# 10_Pet — variables de entorno (copia a .env y rellena)
# NUNCA commitear el .env real. Ver .gitignore.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:5173
# En prod: CORS_ORIGIN debe ser la URL de Vercel (ej: https://10-pet.vercel.app)
CORS_ORIGIN=http://localhost:5173

# Frontend: URL del API backend. En prod Railway: https://[url].railway.app/api/v1
# Solo se usa en build de Vite; en dev el proxy de vite.config.ts lo resuelve solo.
VITE_API_BASE_URL=http://localhost:3000/api/v1

# --- Database (Supabase — Postgres + PostGIS) ---
# Obtener de: Supabase Dashboard > Project Settings > Database > Connection string (URI)
# Usar el modo "Session pooler" o "Direct connection". Activar extensión postgis desde SQL editor:
#   CREATE EXTENSION IF NOT EXISTS postgis;
#   CREATE EXTENSION IF NOT EXISTS pgcrypto;
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- Redis (Upstash — Bull queues) ---
# Obtener de: Upstash Dashboard > Databases > [your db] > REST details (TLS URL)
# Bull requiere el formato rediss:// (TLS) para Upstash
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:[PORT]

# --- JWT ---
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-256-bits-hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Cloudinary (imágenes) ---
# Obtener de: Cloudinary Dashboard > Settings > API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SendGrid (emails) ---
# Crear API key en: SendGrid > Settings > API Keys (full access o restricted a Mail Send)
# Verificar sender domain antes de enviar en prod
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=10_Pet

# --- Firebase (Push FCM) ---
# API backend: obtener del service account JSON (Firebase Console > Project Settings > Service accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Frontend web: obtener de Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Obtener de Firebase Console > Cloud Messaging > Web Push certificates > Key pair
VITE_FIREBASE_VAPID_KEY=

# --- OAuth Google ---
# Obtener de: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# --- Sentry (error tracking) ---
# Crear proyecto "10-pet-api" y "10-pet-web" separados
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_MAX_MUTATIONS=10

# --- Admin ---
# Lista de emails con acceso admin separados por coma (sin espacios)
# Ejemplo: admin@10pet.ar,soporte@10pet.ar
ADMIN_EMAILS=
